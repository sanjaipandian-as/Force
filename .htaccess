# ══════════════════════════════════════════════════════
# PERFORMANCE OPTIMIZED .htaccess — KRM MBBS Seminar
# Targets sub-500ms load time via caching + compression
# ══════════════════════════════════════════════════════

# ── BROTLI COMPRESSION (preferred) ──
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ── GZIP COMPRESSION (fallback) ──
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ── AGGRESSIVE BROWSER CACHING ──
<IfModule mod_expires.c>
  ExpiresActive On
  
  # HTML: Short cache (content may change)
  ExpiresByType text/html "access plus 1 hour"
  
  # Images: Long cache (rarely change)
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  
  # Fonts: Long cache
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  
  # CSS/JS: Long cache
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
</IfModule>

# ── CACHE-CONTROL HEADERS ──
<IfModule mod_headers.c>
  # Immutable assets (images, fonts) — browser never re-validates
  <FilesMatch "\.(webp|avif|jpg|jpeg|png|svg|woff2|css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  
  # HTML — revalidate after 1 hour
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
  
  # Security & Performance headers
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  
  # Remove server signature for speed (smaller response headers)
  Header unset X-Powered-By
  Header unset Server
  
  # Preload hint for hero image via HTTP header
  <FilesMatch "index\.html$">
    Header set Link "<assets/Hereup.webp>; rel=preload; as=image"
  </FilesMatch>
</IfModule>

# ── ETAG: Disable for better caching (Expires is sufficient) ──
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag None

# ── WEBP CONTENT TYPE ──
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/avif .avif
  AddType font/woff2 .woff2
</IfModule>

# ── KEEP-ALIVE (persistent connections) ──
<IfModule mod_headers.c>
  Header set Connection keep-alive
</IfModule>
